# Canonical browser URL (used to derive GOOGLE_REDIRECT_URI if unset)
NEXT_PUBLIC_SITE_URL=https://www.bodymindharmony.co.uk

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# JWT service role, or leave blank and set SUPABASE_SECRET_KEY (Vercel Supabase integration)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
ADMIN_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional if NEXT_PUBLIC_SITE_URL is set (defaults to {origin}/api/google/callback)
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Vercel CLI pull names; push script copies SUPABASE_URL → NEXT_PUBLIC_SUPABASE_URL when needed
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# For npm run db:apply (direct Postgres to Supabase)
# POSTGRES_URL_NON_POOLING=
